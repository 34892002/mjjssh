{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MJJSSH",
  "version": "0.1.0",
  "identifier": "com.mjjssh.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MJJSSH - 连接管理器",
        "width": 1350,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
